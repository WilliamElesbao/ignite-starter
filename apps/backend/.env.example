# Port number for the backend server
PORT=3333

# Web URL for CORS configuration
WEB_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://docker:docker@localhost:5432/ignite-starter

# Redis
REDIS_URL=redis://:abcd1234@localhost:6379

# BetterAuth
BETTER_AUTH_SECRET=<your-secret-key>
# Base URL of your app
BETTER_AUTH_URL=http://localhost:3333

# Google
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# Email
RESEND_API_KEY=<your-resend-api-key>
EMAIL_FROM=delivered@resend.dev
EMAIL_TO=<your-email>

# Stripe
STRIPE_API_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# OpenTelemetry (SigNoz self-hosted or Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ignite-backend

# White listed emails
WHITELISTED_EMAILS=<your-email>,<another-email>
