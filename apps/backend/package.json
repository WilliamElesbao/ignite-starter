{
  "name": "@apps/backend",
  "version": "0.0.0",
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --sourcemap --outdir ./dist",
    "dev": "bun run --watch src/index.ts",
    "worker:email": "bun run ../../packages/backend-base/src/workers/email.worker.ts",
    "lint": "biome check .",
    "lint-fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "latest",
    "@opentelemetry/exporter-trace-otlp-proto": "latest",
    "@opentelemetry/instrumentation-pg": "latest",
    "@opentelemetry/sdk-trace-node": "latest",
    "@repo/backend-base": "*",
    "elysia": "latest"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "bun-types": "latest"
  },
  "module": "src/index.js"
}
