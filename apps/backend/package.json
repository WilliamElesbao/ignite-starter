{
  "name": "@apps/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --sourcemap --outdir ./dist",
    "dev": "bun run --watch src/index.ts",
    "worker:email": "bun run ../../packages/backend-base/src/workers/email.worker.ts",
    "lint": "biome check .",
    "lint-fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "1.4.11",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0",
    "@opentelemetry/instrumentation-pg": "0.70.0",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@repo/backend-base": "workspace:*",
    "elysia": "1.4.28"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "bun-types": "1.3.14"
  }
}
