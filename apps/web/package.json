{
  "name": "@apps/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:watch": "bunx onchange . -- biome check --write --no-errors-on-unmatched {{changed}}",
    "lint-fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "locale-check": "bun run src/scripts/validate-i18n.ts",
    "locale-unused": "bun run src/scripts/check-unused-i18n-keys.ts",
    "check-types": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.6.23",
    "@hookform/resolvers": "^5.2.2",
    "@repo/api": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.101.2",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.0.1",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.72.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^25.0.1",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4.3.0",
    "ts-morph": "^28.0.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  }
}
