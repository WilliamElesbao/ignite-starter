{
  "name": "@apps/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:watch": "bunx onchange . -- biome check --write --no-errors-on-unmatched {{changed}}",
    "lint-fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "locale-check": "bun run src/scripts/validate-i18n.ts",
    "locale-unused": "bun run src/scripts/check-unused-i18n-keys.ts",
    "check-types": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@repo/api": "*",
    "@repo/ui": "*",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "next-intl": "^4.8.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "2.15.4",
    "rocketicons": "^0.2.8",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@repo/typescript-config": "*",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
