{
  "name": "ignite-starter",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ci": "biome ci .",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "tsc": "turbo run check-types",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "check:all": "for d in web backend; do (cd apps/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done && for d in database backend-base api ui emails; do (cd packages/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "turbo": "^2.9.16",
    "typed-css-modules": "^0.9.1",
    "typescript": "5.9.2",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
