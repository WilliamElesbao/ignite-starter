{
  "name": "ignite-starter",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ci": "biome ci .",
    "lint": "turbo run lint",
    "lint-fix": "turbo run lint-fix",
    "format": "turbo run format",
    "tsc": "turbo run check-types",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "check:all": "for d in web backend; do (cd apps/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done && for d in database backend-base api ui emails; do (cd packages/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "bun-types": "latest",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "turbo": "^2.9.16",
    "typed-css-modules": "^0.9.1",
    "typescript": "6.0.3",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
