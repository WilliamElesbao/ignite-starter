{
  "name": "ignite-starter",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ci": "biome ci .",
    "lint": "turbo run lint",
    "lint-fix": "turbo run lint-fix",
    "format": "turbo run format",
    "tsc": "turbo run check-types",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "check:all": "for d in web backend; do (cd apps/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done && for d in database backend-base api ui emails; do (cd packages/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "syncpack": "syncpack lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "husky": "9.1.7",
    "syncpack": "15.3.1",
    "turbo": "2.10.5",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
