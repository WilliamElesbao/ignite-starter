{
  "name": "origin-starter-v2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "lint": "turbo run lint --",
    "lint:fix": "turbo run lint -- --fix",
    "format": "turbo run format",
    "check-types": "turbo run check-types",
    "tsc": "turbo run check-types",
    "check:all": "for d in web backend; do (cd apps/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done && for d in database backend-base api ui emails; do (cd packages/$d && bun biome format . --write && bun biome lint . && bun tsc --noEmit); done",
    "observability:up": "./scripts/observability/signoz-up.sh",
    "observability:down": "./scripts/observability/signoz-down.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  }
}
