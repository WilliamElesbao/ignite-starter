{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@/api/*": ["api/*"],
      "@/lib/*": ["api/src/lib/*"]
