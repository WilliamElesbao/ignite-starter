{
  "name": "@repo/backend-base",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "db:generate": "bun --env-file .env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file .env --bun drizzle-kit migrate",
    "db:studio": "bunx --bun  drizzle-kit studio",
    "lint": "biome check .",
    "lint-fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.6.23",
    "@bull-board/api": "^6.20.6",
    "@bull-board/elysia": "^6.20.6",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/cron": "^1.4.2",
    "@repo/db": "workspace:*",
    "@repo/emails": "workspace:*",
    "better-auth": "^1.6.23",
    "bullmq": "^5.38.2",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "ms": "^2.1.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "resend": "^6.9.4",
    "stripe": "^22.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@repo/typescript-config": "workspace:*",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "bun-types": "1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8"
  }
}
