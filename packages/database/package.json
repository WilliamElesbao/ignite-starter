{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "build": "bun build ./index.ts --target bun --minify --outdir ./dist",
    "db:schema": "bun run --env-file ../backend-base/.env -- bunx --bun @better-auth/cli@latest generate --config ../backend-base/src/lib/better-auth/auth.ts",
    "db:generate": "bun --env-file .env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file .env --bun drizzle-kit migrate",
    "db:seed": "",
    "db:studio": "bunx --bun  drizzle-kit studio",
    "lint": "biome check .",
    "lint-fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/pg": "^8.20.0",
    "bun-types": "1.3.14",
    "drizzle-kit": "^0.31.10",
    "@types/node": "^25.9.2",
    "typescript": "6.0.3"
  }
}
