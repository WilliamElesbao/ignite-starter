{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@repo/frontend-base/constants": ["frontend-base/src/constants/index.ts"],
      "@repo/emails/*": ["emails/src/*"],
      "@/api/*": ["api/*"],
      "@/lib/*": ["api/src/lib/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../frontend-base/src/**/*"],
  "exclude": ["node_modules", ".react-email"]
}
